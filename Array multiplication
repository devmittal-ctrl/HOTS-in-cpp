#include <iostream>
#include <vector>
using namespace std;
int main() {
    // multiplication 2 matrix 
    int arr[3][3], brr[3][3], res[3][3]={0};
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            cin>>arr[i][j];
        }
    }
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            cin>>brr[i][j];
        }
    }
    cout<<endl<<"the first matrix is : "<<endl;
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            cout<<arr[i][j]<<" ";
        }
        cout<<endl;
    }
    cout<<endl<<"the second matrix is : "<<endl;
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            cout<<brr[i][j]<<" ";
        }
        cout<<endl;
    }
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            for(int k=0;k<3;k++){
           res[i][j]+=arr[i][k]*brr[k][j];
        }
        }
        }
    cout<<endl<<"the added matrix is : "<<endl;
     for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            cout<<res[i][j]<<" ";
        }
        cout<<endl;
    }
    return 0;
}
